# Build self-contained ARM wheels for the new OT-2 (Python 3.12, glibc 2.40, Buildroot 2025.02).
#
# Uses arm32v7/python:3.12-slim-bookworm (glibc 2.36) as the build base.
# Bookworm's glibc 2.36 < robot's glibc 2.40, so compiled wheels are compatible.
#
# Compiled from source (no cp312/armv7l wheels on PyPI):
#   - numpy 1.26.x  — no BLAS/LAPACK (libopenblas absent on the new OT-2)
#   - gpiod 1.6.3   — official libgpiod 1.x Python bindings (PascalCase API);
#                     matches the 1.6.x API on the robot (system gpiod 1.6.5)
#
# Downloaded from PyPI (native cp312/armv7l wheels exist):
#   - grpcio        — linux_armv7l wheel available; no compilation needed
#   - opentrons==9.0.0 and all other deps


# Stage 1: compile numpy for cp312/armv7l.
# _PYTHON_HOST_PLATFORM forces linux-armv7l tag: uname -m returns aarch64
# when running arm32v7 containers on an ARM64 host (GitHub Actions ubuntu-24.04-arm).
FROM arm32v7/python:3.12-slim-bookworm AS numpy-builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends build-essential gfortran && \
    rm -rf /var/lib/apt/lists/*

RUN _PYTHON_HOST_PLATFORM=linux-armv7l \
    NPY_BLAS_ORDER="" NPY_LAPACK_ORDER="" \
    pip wheel "numpy>=1.26,<2" --no-deps --wheel-dir=/numpy-output/


# Stage 2: compile gpiod Python bindings for cp312/armv7l.
# Same approach as the py310 build: build from libgpiod 1.6.3 source.
# The tarball includes a pre-generated configure script.
FROM arm32v7/python:3.12-slim-bookworm AS gpiod-builder

RUN apt-get update && \
    apt-get install -y --no-install-recommends \
        build-essential wget ca-certificates pkg-config && \
    rm -rf /var/lib/apt/lists/*

RUN wget -q https://mirrors.edge.kernel.org/pub/software/libs/libgpiod/libgpiod-1.6.3.tar.gz && \
    tar xzf libgpiod-1.6.3.tar.gz && \
    cd libgpiod-1.6.3 && \
    ./configure --prefix=/usr/local --enable-shared --disable-static && \
    make -j$(nproc) && \
    make install && \
    echo /usr/local/lib > /etc/ld.so.conf.d/local.conf && ldconfig && \
    cd bindings/python && \
    printf '%s\n' \
        'from setuptools import setup, Extension' \
        'setup(name="gpiod", version="1.6.3", ext_modules=[Extension(' \
        '    "gpiod", sources=["gpiodmodule.c"],' \
        '    libraries=["gpiod"], library_dirs=["/usr/local/lib"],' \
        '    include_dirs=["/usr/local/include"])])' \
        > setup.py && \
    _PYTHON_HOST_PLATFORM=linux-armv7l \
    pip wheel . --no-deps --wheel-dir=/gpiod-output/ && \
    cd / && rm -rf libgpiod-1.6.3*


# Stage 3: build our package and download remaining deps.
FROM arm32v7/python:3.12-slim-bookworm AS builder

WORKDIR /build
# git: needed below to pip-download robot_server and its monorepo siblings from source
# (not on PyPI); slim-bookworm doesn't include it by default.
RUN apt-get update && \
    apt-get install -y --no-install-recommends git && \
    rm -rf /var/lib/apt/lists/*
RUN pip install --upgrade pip wheel build uv

COPY pyproject.toml README.md ./
COPY src/ src/
COPY config/ config/

# Resolve the full dep tree from pyproject.toml (python_version markers select 3.12 deps).
# Exclude packages compiled from source in earlier stages (numpy, gpiod),
# grpcio (downloaded separately for the linux_armv7l wheel tag), and
# pydantic, opentrons, uvicorn, wsproto (bundled below instead, as part of a single
# internally-consistent set with robot_server -- see that comment for why).
RUN python -m build --wheel && \
    mkdir -p /output && \
    cp dist/*.whl /output/ && \
    uv pip compile --python-version 3.12 pyproject.toml > /tmp/resolved.txt && \
    grep -v '^numpy\|^grpcio\|^gpiod\|^pydantic\|^opentrons\|^uvicorn\|^wsproto\|^python-dotenv' /tmp/resolved.txt > /tmp/resolved_filtered.txt && \
    pip download --no-deps -d /output/ \
        --platform manylinux_2_17_armv7l --platform linux_armv7l \
        --python-version 312 --implementation cp --abi cp312 \
        -r /tmp/resolved_filtered.txt

# grpcio: native cp312/linux_armv7l wheel on PyPI (no compilation needed)
RUN pip download --no-deps -d /output/ \
        --platform linux_armv7l \
        --python-version 312 --implementation cp --abi cp312 \
        grpcio

COPY --from=numpy-builder /numpy-output/numpy-*.whl /output/
COPY --from=gpiod-builder /gpiod-output/gpiod-*.whl /output/

# robot_server is not on PyPI -- only in the Opentrons monorepo on GitHub. Different
# physical OT-2 units have drifted to different system fastapi/pydantic versions
# (confirmed: one robot has fastapi 0.100.0/pydantic 2.11.7, another has the much
# older fastapi 0.99.1/pydantic 1.10.12 -- real pydantic v1, incompatible with this
# project's own pydantic-v2-only code in one process). Bundling one fixed,
# internally-consistent set ourselves -- instead of relying on whatever a given
# robot's system happens to have -- removes that variability entirely. This mirrors
# .github/workflows/test.yml's own robot_server integration tests exactly, which
# already prove this combination works together.
#
# opentrons/opentrons_shared_data/opentrons_hardware are reinstalled from git (not
# just the PyPI opentrons==9.0.0 wheel above) because the PyPI build omits symbols
# robot_server imports. pip wheel (not pip download): pip download saves a VCS source
# as a raw .zip source tree, not an actual .whl -- confirmed directly -- so the later
# `pip install /wheels/*.whl` would silently skip it. pip wheel builds and saves a real
# wheel, same tool already used for gpiod/numpy above. No --platform/--abi flags: these
# are pure-Python VCS sources pip must build, and this container already IS the target
# arch/Python version, so it builds correctly without them.
RUN pip wheel --no-deps --wheel-dir=/output/ \
        "opentrons @ git+https://github.com/Opentrons/opentrons.git@v9.0.0#subdirectory=api" \
        "opentrons_shared_data @ git+https://github.com/Opentrons/opentrons.git@v9.0.0#subdirectory=shared-data" \
        "opentrons_hardware @ git+https://github.com/Opentrons/opentrons.git@v9.0.0#subdirectory=hardware" \
        "robot_server @ git+https://github.com/Opentrons/opentrons.git@v9.0.0#subdirectory=robot-server" \
        "server_utils @ git+https://github.com/Opentrons/opentrons.git@v9.0.0#subdirectory=server-utils"

# robot_server's own non-monorepo runtime deps, pinned to the exact versions
# .github/workflows/test.yml already proves compatible with it. --only-binary=:all:
# (required alongside --platform/--python-version/--abi unless --no-deps is used) is
# fine here -- unlike aiohttp/sqlalchemy below, transitive deps of this set (starlette,
# anyio, click, h11, etc.) are expected to have ordinary prebuilt wheels.
RUN pip download -d /output/ \
        --platform manylinux_2_17_armv7l --platform linux_armv7l \
        --python-version 312 --implementation cp --abi cp312 --only-binary=:all: \
        "fastapi==0.100.0" \
        "pydantic==2.11.7" \
        "pydantic-settings==2.4.0" \
        "python-dotenv==1.0.1" \
        "python-multipart==0.0.6" \
        "uvicorn==0.27.0.post1" \
        "wsproto==1.2.0"

# paho-mqtt==1.6.1 only ever published an sdist, no wheel -- --only-binary=:all: above
# would reject it. It's pure Python with no deps of its own, so build it directly with
# no platform restriction (same reasoning as the git packages above). pip wheel, not
# pip download -- see comment above the git packages for why.
RUN pip wheel --no-deps --wheel-dir=/output/ "paho-mqtt==1.6.1"

# aiohttp and sqlalchemy==1.4.51 have no prebuilt armv7l wheels for cp312 (checked
# directly against piwheels.org). Both have official, documented pure-Python build
# modes, sidestepping the need for a cross-compile toolchain entirely:
#   - aiohttp: AIOHTTP_NO_EXTENSIONS=1
#   - SQLAlchemy: DISABLE_SQLALCHEMY_CEXT=1 (documented since 0.8.6/0.9.4)
# pip wheel, not pip download -- see comment above the git packages for why.
RUN AIOHTTP_NO_EXTENSIONS=1 DISABLE_SQLALCHEMY_CEXT=1 \
    pip wheel --no-binary aiohttp --no-binary sqlalchemy --wheel-dir=/output/ \
        "aiohttp" \
        "sqlalchemy==1.4.51"


# Stage 4: Build single self-contained connector binary for cp312/armv7l using PyInstaller.
# Based on gpiod-builder: Bookworm + Python 3.12 + libgpiod.so.2 at /usr/local/lib.
# The binary targets the new OT-2 (glibc 2.40). Bookworm glibc 2.36 < 2.40 — compatible.
FROM gpiod-builder AS pyinstaller-builder

# All wheels (pure-Python + C extensions) come from the builder stage's /output --
# including robot_server and its full matched dependency set.
COPY --from=builder /output/ /wheels/

RUN pip install --no-deps /wheels/*.whl

# Build the PyInstaller bootloader from source for armv7l on Bookworm.
# PyInstaller ships pre-built bootloaders for x86/x86_64/aarch64 only — not armv7l.
# zlib1g-dev is needed by waf; build-essential is already present from gpiod-builder.
RUN apt-get update && \
    apt-get install -y --no-install-recommends zlib1g-dev && \
    rm -rf /var/lib/apt/lists/* && \
    pip install "setuptools<80" pyinstaller-hooks-contrib && \
    wget -q https://github.com/pyinstaller/pyinstaller/archive/refs/tags/v5.13.2.tar.gz && \
    tar xzf v5.13.2.tar.gz && \
    cd pyinstaller-5.13.2/bootloader && \
    python3 ./waf all && \
    cd ../.. && \
    pip install ./pyinstaller-5.13.2/ && \
    rm -rf pyinstaller-5.13.2 v5.13.2.tar.gz

# Smoke-test imports before PyInstaller runs — fails fast if any package is missing.
RUN python3 -c "import grpc, gpiod, opentrons, numpy, robot_server, unitelabs.opentrons_ot2; print('imports OK: grpc=%s numpy=%s' % (grpc.__version__, numpy.__version__))"

# Build the connector binary.
# --add-binary bundles libgpiod.so.2 (compiled in gpiod-builder) so the extension resolves
# it from inside the bundle via PyInstaller's LD_LIBRARY_PATH, not the system.
RUN _PYTHON_HOST_PLATFORM=linux-armv7l \
    pyinstaller \
        --onefile \
        --name connector \
        --collect-all opentrons \
        --collect-all opentrons_shared_data \
        --collect-all unitelabs \
        --collect-all zeroconf \
        --collect-all robot_server \
        --collect-all fastapi \
        --hidden-import grpc._cython.cygrpc \
        --add-binary '/usr/local/lib/libgpiod.so.2:.' \
        --distpath /exe-output/ \
        /usr/local/bin/connector

# Smoke-test the frozen binary itself — catches missing hidden imports and data files.
RUN /exe-output/connector --help

# Real smoke test: actually start the app with with_robot_server=true (simulator mode)
# and confirm it reaches a running state instead of crashing during create_app(). Fully
# testable in CI now that robot_server no longer depends on a real robot's system Python.
COPY config/ot2_config.json /tmp/ot2_config.json
RUN python3 -c "\
import json; \
cfg = json.load(open('/tmp/ot2_config.json')); \
cfg['use_simulator'] = True; \
cfg['with_robot_server'] = True; \
cfg['robot_server_tcp_port'] = 8080; \
cfg['sila_server']['port'] = 0; \
json.dump(cfg, open('/tmp/smoke_config.json', 'w'))" && \
    (timeout 20 /exe-output/connector start --app unitelabs.opentrons_ot2:create_app --config-path /tmp/smoke_config.json > /tmp/smoke.log 2>&1 &) && \
    sleep 15 && \
    cat /tmp/smoke.log && \
    grep -q "SiLA server listening" /tmp/smoke.log
